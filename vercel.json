{
  "version": 2,
  "buildCommand": "cd frontend && npm install --legacy-peer-deps && CI=false npm run build",
  "outputDirectory": "frontend/build",
  "functions": {
    "api/index.py": {
      "runtime": "@vercel/python@4.5.0"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/((?!api|static|icons|manifest|service-worker|robots|sitemap).*)", "destination": "/index.html" }
  ]
}
